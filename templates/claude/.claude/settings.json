{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "cr boundary check-note --file memory/task_note.json"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cr boundary check-note --file memory/task_note.json"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "git diff --no-ext-diff -- . > .chay/tmp/current.diff && cr patch check --diff .chay/tmp/current.diff --work memory/codex_work_note.json"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Read(audit/**)",
      "Read(**/*.md)",
      "Bash(rm -rf *)",
      "Bash(git push *)",
      "Bash(git reset --hard *)"
    ]
  }
}
